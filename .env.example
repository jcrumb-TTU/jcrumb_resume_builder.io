# ============================================================
# Resume Builder — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# This file is listed in .gitignore.
# ============================================================

# Google Gemini API Key
# Obtain a free API key from https://aistudio.google.com/apikey
# Select the Gemini 2.5 Flash model when generating your key.
# The free tier allows 10 requests per minute and 500 per day.
GEMINI_API_KEY=your_gemini_api_key_here

# Express Server Port
# This is the port your local Express server listens on.
# Default is 3000. Only change this if port 3000 is in use.
HTTP_PORT=3000

